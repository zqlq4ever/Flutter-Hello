<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Theme applied while Flutter initializes (pre-first-frame).
      Keep it lightweight and deterministic to avoid black/white flash.
    -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <!--
      Theme applied after Flutter has rendered the first frame.
      Also provides the background behind Flutter surfaces.
    -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
</resources>
